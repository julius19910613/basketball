<view class="player-card">
  <!-- 卡片头部 -->
  <view class="card-header">
    <image class="avatar" src="{{player.avatarUrl || '/images/default_avatar.svg'}}" mode="aspectFill" />
    <view class="info">
      <text class="name">{{player.nickName || '匿名球员'}}</text>
      <view class="pos-tag" style="background: {{positionInfo.color}}; color: #fff;">
        <text>{{positionInfo.name || '未知位置'}}</text>
      </view>
    </view>
    <view class="overall-box" style="border-color: {{positionInfo.color}}">
      <text class="overall-val" style="color: {{positionInfo.color}}">{{overall}}</text>
      <text class="overall-lbl">OVR</text>
    </view>
  </view>

  <!-- 技能概要 -->
  <view class="skills-section">
    <view class="section-title">核心能力</view>
    <view class="skill-bar" wx:for="{{skillSummary}}" wx:key="label">
      <view class="skill-info">
        <text class="skill-name">{{item.label}}</text>
        <text class="skill-val">{{item.value}}</text>
      </view>
      <view class="skill-progress">
        <view class="progress-fill" style="width: {{item.value}}%; background: {{positionInfo.color}}"></view>
      </view>
    </view>
  </view>

  <!-- 身体数据 -->
  <view class="physical-section">
    <view class="physical-item">
      <text class="p-value">{{player.height || '--'}}</text>
      <text class="p-label">身高</text>
    </view>
    <view class="physical-item">
      <text class="p-value">{{player.weight || '--'}}</text>
      <text class="p-label">体重</text>
    </view>
  </view>
</view>
