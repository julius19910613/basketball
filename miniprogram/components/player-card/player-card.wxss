.player-card {
  position: relative;
  width: 680rpx; /* 固定宽度，适应屏幕 */
  margin: 40rpx auto;
  background-color: #2C3E50; /* 深灰蓝背景 */
  border-radius: 24rpx;
  border: 2rpx solid #00FFFF; /* 电光蓝边框 */
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.6), inset 0 0 30rpx rgba(0, 255, 255, 0.2);
  overflow: hidden;
  color: #F5F5DC; /* 亮米白文字 */
  font-family: 'DM Serif Display', serif; /* 正文字体 */
  padding-bottom: 30rpx;
  transform: rotate(-2deg); /* 轻微倾斜，增加动感 */
  transform-origin: center center;
}

.card-diagonal-bg {
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(45deg, rgba(255, 107, 53, 0.5) 0%, rgba(0, 255, 255, 0.5) 100%); /* 橙色到电光蓝渐变 */
  transform: rotate(30deg);
  border-radius: 50%;
  filter: blur(20rpx);
  opacity: 0.3;
  z-index: 0;
}

.card-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 40rpx;
  background-color: rgba(255, 107, 53, 0.1); /* 橙色半透明叠加 */
  border-bottom: 1rpx solid rgba(0, 255, 255, 0.3);
}

.card-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid #00FF00; /* 荧光绿边框 */
  box-shadow: 0 0 15rpx rgba(0, 255, 0, 0.5);
  margin-right: 30rpx;
}

.nickname-section {
  display: flex;
  flex-direction: column;
}

.card-nickname {
  font-family: 'Space Mono', monospace; /* 标题字体 */
  font-size: 40rpx;
  color: #FF6B35; /* 橙色昵称 */
  font-weight: bold;
  letter-spacing: 1rpx;
  text-shadow: 1rpx 1rpx 3rpx rgba(0, 0, 0, 0.3);
}

.card-position {
  font-size: 28rpx;
  color: #00FFFF; /* 电光蓝位置信息 */
  margin-top: 5rpx;
  font-family: 'DM Serif Display', serif; /* 正文字体 */
}

.card-data-section {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  padding: 40rpx 30rpx;
  border-bottom: 1rpx dashed rgba(0, 255, 255, 0.2);
}

.data-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 45%; /* 每行两个 */
  margin-bottom: 30rpx;
  padding: 20rpx 0;
  border: 1rpx solid rgba(255, 107, 53, 0.1); /* 橙色细边 */
  border-radius: 12rpx;
  background-color: rgba(0, 0, 0, 0.1);
  box-shadow: inset 0 0 10rpx rgba(0, 255, 255, 0.1);
  transition: all 0.2s ease;
}
.data-item:hover {
  background-color: rgba(0, 255, 255, 0.05);
}

.data-item.full-width {
  width: 95%; /* 技能占满一行 */
  margin-top: 10rpx;
  margin-bottom: 0;
}

.data-value {
  font-family: 'Space Mono', monospace; /* 标题字体 */
  font-size: 44rpx;
  color: #00FF00; /* 荧光绿数据 */
  font-weight: bold;
  letter-spacing: 1.5rpx;
  margin-bottom: 5rpx;
}
.data-value.skills-text {
  font-size: 30rpx;
  text-align: center;
  color: #FF6B35;
}


.data-label {
  font-size: 24rpx;
  color: rgba(245, 245, 220, 0.7);
  text-transform: uppercase;
  font-family: 'DM Serif Display', serif; /* 正文字体 */
}

.card-stats-section {
  position: relative;
  z-index: 1;
  padding: 30rpx;
}

.stats-title {
  font-family: 'Space Mono', monospace; /* 标题字体 */
  font-size: 32rpx;
  color: #F5F5DC;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
  text-align: center;
  border-bottom: 1rpx solid rgba(255, 107, 53, 0.2);
  padding-bottom: 10rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  text-align: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx 0;
}

.stat-value {
  font-family: 'Space Mono', monospace; /* 标题字体 */
  font-size: 38rpx;
  color: #00FFFF; /* 电光蓝统计值 */
  font-weight: bold;
  margin-bottom: 5rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(245, 245, 220, 0.6);
  font-family: 'DM Serif Display', serif; /* 正文字体 */
}

.card-footer {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 15rpx;
  background: linear-gradient(90deg, #FF6B35 0%, #00FF00 50%, #00FFFF 100%); /* 底部彩色渐变条 */
  opacity: 0.6;
}
