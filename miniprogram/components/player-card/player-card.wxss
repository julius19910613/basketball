.player-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #eee;
}
.info {
  flex: 1;
}
.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.pos-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}
.overall-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  border: 4rpx solid;
}
.overall-val {
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}
.overall-lbl {
  font-size: 18rpx;
  color: #999;
  margin-top: 4rpx;
}
.skills-section {
  margin-top: 24rpx;
  padding: 0 16rpx;
}
.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}
.skill-bar {
  margin-bottom: 20rpx;
}
.skill-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.skill-name {
  font-size: 26rpx;
  color: #666;
}
.skill-val {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}
.skill-progress {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  transition: width 0.3s;
}
.physical-section {
  display: flex;
  justify-content: space-around;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}
.physical-item {
  text-align: center;
}
.p-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.p-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
