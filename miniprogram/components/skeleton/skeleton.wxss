/* components/skeleton/skeleton.wxss */

/* 骨架屏容器 */
.skeleton-container {
  padding: 30rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

/* 通用占位块样式 */
.skeleton-shimmer {
  background: linear-gradient(
    90deg,
    #F2F2F2 25%,
    #E6E6E6 37%,
    #F2F2F2 63%
  );
  background-size: 400% 100%;
  animation: shimmer 1.5s ease infinite;
  border-radius: 8rpx;
}

/* 扫光动画 */
@keyframes shimmer {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}

/* 头部骨架 */
.skeleton-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.skeleton-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.skeleton-title-group {
  flex: 1;
  margin-left: 24rpx;
}

.skeleton-title {
  height: 36rpx;
  width: 200rpx;
  margin-bottom: 16rpx;
}

.skeleton-subtitle {
  height: 24rpx;
  width: 300rpx;
}

/* 统计卡片骨架 */
.skeleton-stats {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.skeleton-stats-header {
  height: 32rpx;
  width: 150rpx;
  margin-bottom: 30rpx;
}

.skeleton-stats-dots {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.skeleton-dot-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.skeleton-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
}

.skeleton-dot-label {
  width: 60rpx;
  height: 24rpx;
}

.skeleton-stats-footer {
  height: 28rpx;
  width: 200rpx;
  margin-top: 20rpx;
}

/* 快捷操作骨架 */
.skeleton-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.skeleton-action-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.skeleton-action-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.skeleton-action-content {
  flex: 1;
  margin-left: 20rpx;
}

.skeleton-action-title {
  height: 28rpx;
  width: 160rpx;
  margin-bottom: 10rpx;
}

.skeleton-action-desc {
  height: 22rpx;
  width: 200rpx;
}

.skeleton-action-arrow {
  width: 20rpx;
  height: 20rpx;
  flex-shrink: 0;
  border-radius: 4rpx;
}

/* 列表骨架 */
.skeleton-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.skeleton-list-header {
  height: 32rpx;
  width: 200rpx;
  margin-bottom: 24rpx;
}

.skeleton-list-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F2F2F2;
}

.skeleton-list-item:last-child {
  border-bottom: none;
}

.skeleton-item-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.skeleton-item-content {
  flex: 1;
  margin-left: 20rpx;
}

.skeleton-item-title {
  height: 28rpx;
  width: 150rpx;
  margin-bottom: 12rpx;
}

.skeleton-item-desc {
  height: 20rpx;
  width: 100rpx;
}

.skeleton-item-tag {
  width: 60rpx;
  height: 40rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.skeleton-item-arrow {
  width: 20rpx;
  height: 20rpx;
  margin-left: 10rpx;
  flex-shrink: 0;
}

/* 卡片骨架 */
.skeleton-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-stats-row {
  height: 80rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.skeleton-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.skeleton-card-title {
  height: 32rpx;
  width: 120rpx;
}

.skeleton-card-badge {
  height: 28rpx;
  width: 80rpx;
  border-radius: 14rpx;
}

.skeleton-card-avatars {
  display: flex;
  gap: 10rpx;
}

.skeleton-card-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

/* 选择器骨架 */
.skeleton-selector {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-selector-header {
  height: 40rpx;
  width: 200rpx;
  border-radius: 8rpx;
}

.skeleton-selector-row {
  height: 80rpx;
  border-radius: 16rpx;
}

.skeleton-selector-groups {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-selector-group {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.skeleton-group-header {
  height: 28rpx;
  width: 180rpx;
  margin-bottom: 20rpx;
}

.skeleton-group-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.skeleton-chip {
  width: 100rpx;
  height: 60rpx;
  border-radius: 30rpx;
}

/* 深色主题 */
.skeleton-container.dark {
  background: #1a1a1a;
}

.skeleton-container.dark .skeleton-shimmer {
  background: linear-gradient(
    90deg,
    #2a2a2a 25%,
    #3a3a3a 37%,
    #2a2a2a 63%
  );
  background-size: 400% 100%;
}

.skeleton-container.dark .skeleton-header,
.skeleton-container.dark .skeleton-stats,
.skeleton-container.dark .skeleton-action-item,
.skeleton-container.dark .skeleton-list,
.skeleton-container.dark .skeleton-card,
.skeleton-container.dark .skeleton-selector-group {
  background: #2a2a2a;
}
