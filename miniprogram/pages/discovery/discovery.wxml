<!--pages/discovery/discovery.wxml-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索球队、球友..." bindinput="onSearchInput" />
  </view>

  <!-- 附近球队 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">附近球队</text>
      <text class="section-more" bindtap="seeMoreTeams">查看更多 ></text>
    </view>
    <scroll-view class="team-scroll" scroll-x="true" wx:if="{{nearbyTeams.length > 0}}">
      <view class="team-card" wx:for="{{nearbyTeams}}" wx:key="_id" bindtap="goToTeam" data-id="{{item._id}}">
        <image class="team-logo" src="{{item.logo || '/images/basketball-placeholder.svg'}}" mode="aspectFill"></image>
        <text class="team-name">{{item.name}}</text>
        <text class="team-region">{{item.region}}</text>
      </view>
    </scroll-view>
    <view class="placeholder" wx:else>
      <text class="placeholder-icon">🏀</text>
      <text class="placeholder-text">暂无附近球队</text>
    </view>
  </view>

  <!-- 约球信息 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">约球信息</text>
      <text class="section-more" bindtap="seeMoreActivities">查看更多 ></text>
    </view>
    <view class="placeholder">
      <text class="placeholder-icon">📢</text>
      <text class="placeholder-text">功能开发中</text>
      <text class="placeholder-sub">敬请期待</text>
    </view>
  </view>

  <!-- 动态广场 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">动态广场</text>
    </view>
    <view class="placeholder">
      <text class="placeholder-icon">💬</text>
      <text class="placeholder-text">功能开发中</text>
      <text class="placeholder-sub">敬请期待</text>
    </view>
  </view>
</view>
