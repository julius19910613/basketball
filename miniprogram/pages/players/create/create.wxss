.container {
  min-height: 100vh;
  background: #f4f8ff;
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #d9e4fb;
  padding: 28rpx;
  box-shadow: 0 6rpx 16rpx rgba(22, 82, 240, 0.08);
}

.title {
  font-size: 36rpx;
  color: #0f172a;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 18rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

.input,
.picker {
  width: 100%;
  min-height: 76rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d9e4fb;
  background: #f8fbff;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #0f172a;
  box-sizing: border-box;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.half {
  flex: 1;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx 28rpx;
  background: #fff;
  border-top: 1rpx solid #d9e4fb;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  background: linear-gradient(135deg, #1652f0 0%, #3b82f6 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.submit-btn[disabled] {
  background: #cbd5e1;
}
