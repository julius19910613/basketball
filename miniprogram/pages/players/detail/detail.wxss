.container {
  min-height: 100vh;
  background: #f4f8ff;
  padding: 24rpx;
}

.loading,
.error-wrap {
  margin-top: 160rpx;
  text-align: center;
  color: #64748b;
}

.error {
  color: #dc2626;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #d9e4fb;
  padding: 28rpx;
  box-shadow: 0 6rpx 16rpx rgba(22, 82, 240, 0.08);
}

.head {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.nickname {
  display: block;
  font-size: 38rpx;
  color: #0f172a;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.position {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #1652f0;
  font-size: 22rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.row:last-child {
  border-bottom: none;
}

.label {
  color: #64748b;
  font-size: 24rpx;
}

.value {
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 600;
}
