<!--pages/create-team/create-team.wxml-->
<view class="container">
  <view class="form">
    <!-- 队名 -->
    <view class="form-item">
      <text class="label">队名 *</text>
      <input 
        class="input" 
        placeholder="请输入球队名称" 
        value="{{formData.name}}"
        bindinput="inputName"
        maxlength="20"
      />
    </view>

    <!-- 地区 -->
    <view class="form-item">
      <text class="label">地区 *</text>
      <input 
        class="input" 
        placeholder="请输入球队所在地区" 
        value="{{formData.region}}"
        bindinput="inputRegion"
        maxlength="20"
      />
    </view>

    <!-- 队徽 -->
    <view class="form-item">
      <text class="label">队徽</text>
      <view class="logo-box" bindtap="chooseLogo">
        <image 
          wx:if="{{formData.logo}}" 
          src="{{formData.logo}}" 
          mode="aspectFill"
          class="logo-image"
        ></image>
        <view wx:else class="logo-placeholder">
          <text class="placeholder-icon">+</text>
          <text class="placeholder-text">点击选择队徽</text>
        </view>
      </view>
    </view>

    <!-- 队服颜色 -->
    <view class="form-item">
      <text class="label">队服颜色</text>
      <view class="color-box" bindtap="chooseColor">
        <view class="color-preview" style="background-color: {{formData.color}};"></view>
        <text class="color-text">点击选择颜色</text>
      </view>
    </view>

    <!-- 提交按钮 -->
    <button class="submit-btn" bindtap="submit" loading="{{uploading}}">
      {{uploading ? '上传中...' : '创建球队'}}
    </button>
  </view>
</view>
