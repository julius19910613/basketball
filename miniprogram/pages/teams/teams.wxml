<!--pages/teams/teams.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <text class="title">我的球队</text>
    <button class="create-btn" bindtap="createTeam">创建球队</button>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{teamList.length === 0 && !loading}}">
    <image src="/images/empty-team.png" mode="aspectFit" class="empty-image"></image>
    <text class="empty-text">还没有球队</text>
    <text class="empty-hint">点击"创建球队"开始组建你的篮球队</text>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 球队列表 -->
  <view class="team-list" wx:if="{{teamList.length > 0}}">
    <view class="team-item" wx:for="{{teamList}}" wx:key="_id" data-id="{{item._id}}" bindtap="goToTeamDetail">
      <!-- 队徽 -->
      <image class="team-logo" src="{{item.logo || '/images/default-logo.png'}}" mode="aspectFill"></image>
      
      <!-- 球队信息 -->
      <view class="team-info">
        <view class="team-name">{{item.name}}</view>
        <view class="team-meta">
          <text class="team-region">{{item.region}}</text>
          <text class="team-color" style="background-color: {{item.color}};"></text>
        </view>
        <view class="team-role" wx:if="{{item.myRole === 'captain'}}">队长</view>
        <view class="team-role vice" wx:elif="{{item.myRole === 'vice-captain'}}">副队长</view>
      </view>

      <!-- 箭头 -->
      <view class="arrow">></view>
    </view>
  </view>
</view>
