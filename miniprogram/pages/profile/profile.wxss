.container {
  min-height: 100vh;
  background: #f4f8ff;
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* 头部卡片 */
.profile-card {
  background: linear-gradient(135deg, #1652f0 0%, #3b82f6 100%);
  border-radius: 20rpx;
  padding: 40rpx 28rpx;
  margin-bottom: 20rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
}

.profile-info {
  flex: 1;
}

.profile-info .nickname {
  display: block;
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.linked-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 22rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #d9e4fb;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(22, 82, 240, 0.08);
}

.section-title {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 700;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #64748b;
  font-size: 24rpx;
}

.info-value {
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 600;
}

/* 编辑头像行 */
.edit-avatar-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.avatar-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-small {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.change-text {
  color: #1652f0;
  font-size: 24rpx;
}

.nickname-edit {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #1652f0;
  font-weight: 600;
}

/* 按钮 */
.btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  border: none;
  padding: 0 32rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #1652f0;
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: #1652f0;
  border: 1rpx solid #1652f0;
}

.btn-danger {
  background: #fff;
  color: #dc2626;
  border: 1rpx solid #dc2626;
}

.btn-block {
  width: 100%;
  margin-top: 16rpx;
}

.btn[disabled] {
  background: #cbd5e1;
  color: #fff;
  border-color: #cbd5e1;
}

/* 危险区域 */
.danger-zone {
  border-color: #fecaca;
}

.danger-zone .section-title {
  color: #dc2626;
}

.danger-desc {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 16rpx;
}

/* 引导卡片 */
.guide-card {
  background: linear-gradient(135deg, #1652f0 0%, #3b82f6 100%);
  border-radius: 20rpx;
  padding: 48rpx 28rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.guide-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
}

.guide-title {
  display: block;
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.guide-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 球员选择列表 */
.player-list {
  margin-bottom: 16rpx;
}

.player-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  transition: all 0.2s;
}

.player-item.selected {
  border-color: #1652f0;
  background: #eef4ff;
}

.player-name {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
}

.player-meta {
  font-size: 22rpx;
  color: #64748b;
  flex: 1;
  margin-left: 16rpx;
}

.check-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  background: #1652f0;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.empty-tip {
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
  padding: 30rpx 0;
}
