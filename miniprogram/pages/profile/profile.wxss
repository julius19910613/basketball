/* 特定表单项的布局调整，实现非对称感 */
.form-item-height {
  margin-left: 20rpx; /* 稍微右移 */
  width: 90%; /* 宽度调整 */
  transform: rotate(-1deg); /* 轻微旋转 */
  transform-origin: center right;
}
.form-item-weight {
  margin-top: -10rpx; /* 稍微上移，与上一个元素重叠 */
  margin-right: 30rpx; /* 稍微左移 */
  width: 85%;
  transform: rotate(2deg); /* 轻微旋转 */
  transform-origin: center left;
}
.form-item-position {
  margin-left: 40rpx;
  width: 92%;
  transform: rotate(-0.5deg);
  transform-origin: center center;
}
.form-item-skills {
  margin-top: -5rpx;
  margin-right: 10rpx;
  width: 88%;
  transform: rotate(1.5deg);
  transform-origin: center right;
}