<view class="container">
  <view wx:if="{{loading}}" class="status">加载中...</view>
  <view wx:elif="{{!match}}" class="status">比赛不存在</view>
  <view wx:else>
    <view class="card header-card">
      <text class="title">比赛分组</text>
      <text class="meta">{{matchTeamsText}} · {{match.matchDate}}</text>
      <text class="meta">状态：{{statusText}}</text>
    </view>

    <view class="action-row">
      <button class="btn btn-secondary" bindtap="onShowPlayerPicker" disabled="{{match.status==='finalized'}}">添加球员</button>
      <button class="btn btn-secondary" bindtap="onAutoBalance" disabled="{{match.status==='finalized'}}">一键均衡分组</button>
    </view>

    <view class="card">
      <view class="section-title">未分组球员（{{unassignedPlayers.length}}）</view>
      <view wx:if="{{!unassignedPlayers.length}}" class="empty">暂无未分组球员</view>
      <view wx:for="{{unassignedPlayers}}" wx:key="playerId" wx:for-item="unassigned" class="player-row">
        <view>
          <text class="name">{{unassigned.displayNickname}}</text>
          <text class="pos">{{unassigned.displayPosition}}</text>
        </view>
        <view class="ops">
          <button wx:for="{{groupedPlayers}}" wx:key="teamName" wx:for-item="team" class="mini" data-id="{{unassigned.playerId}}" data-target-index="{{index}}" bindtap="onMovePlayer" disabled="{{match.status==='finalized'}}">{{team.teamName}}</button>
        </view>
      </view>
    </view>

    <view class="team-wrap">
      <view wx:for="{{groupedPlayers}}" wx:key="teamName" wx:for-item="group" class="card team-card">
        <view class="section-title">{{group.teamName}}（{{group.players.length}}）</view>
        <view wx:if="{{!group.players.length}}" class="empty">暂无球员</view>
        <view wx:for="{{group.players}}" wx:key="playerId" wx:for-item="member" class="player-row">
          <view>
            <text class="name">{{member.displayNickname}}</text>
            <text class="pos">{{member.displayPosition}}</text>
          </view>
          <view class="ops">
            <button
              wx:for="{{groupedPlayers}}"
              wx:key="teamName"
              wx:for-item="targetTeam"
              wx:if="{{targetTeam.teamName !== group.teamName}}"
              class="mini"
              data-id="{{member.playerId}}"
              data-target-index="{{index}}"
              bindtap="onMovePlayer"
              disabled="{{match.status==='finalized'}}"
            >
              到{{targetTeam.teamName}}
            </button>
          </view>
        </view>
      </view>
    </view>

    <view class="footer">
      <button class="btn btn-secondary" bindtap="onSaveDraft" loading="{{saving}}" disabled="{{saving || match.status==='finalized'}}">保存草稿</button>
      <button class="btn btn-primary" bindtap="onFinalize" loading="{{saving}}" disabled="{{saving || match.status==='finalized'}}">完成并锁定</button>
    </view>
  </view>

  <van-popup show="{{showPlayerPicker}}" position="bottom" round custom-style="height: 70%;" bind:close="onHidePlayerPicker">
    <view class="popup-container">
      <view class="popup-header">
        <text class="popup-title">选择参赛球员</text>
        <van-button type="primary" size="small" round bind:click="onConfirmPlayerPicker">确定</van-button>
      </view>
      <scroll-view scroll-y class="player-list-scroll">
        <van-checkbox-group value="{{tempSelectedPlayerIds}}" bind:change="onPlayerSelectionChange">
          <van-cell-group border="{{ false }}">
            <van-cell wx:for="{{players}}" wx:key="playerId" title="{{item.displayNickname}}" label="{{item.displayPosition}}">
              <van-checkbox slot="right-icon" name="{{item.playerId}}" />
            </van-cell>
          </van-cell-group>
        </van-checkbox-group>
      </scroll-view>
    </view>
  </van-popup>
</view>
