/* pages/match/create-match/create-match.wxss */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
}

/* Form Section */
.form-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

/* Form Item */
.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-picker {
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.form-picker.placeholder {
  color: #999;
}

/* Team Selection */
.team-selector {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
}

.team-logo {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #eee;
  margin-right: 16rpx;
}

.team-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.team-placeholder {
  color: #999;
}

.team-arrow {
  font-size: 28rpx;
  color: #999;
}

/* Match Type Selection */
.type-selector {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.type-option.active {
  background-color: #FF6B35;
  color: #fff;
}

/* Location Input */
.location-input {
  display: flex;
  align-items: center;
}

.location-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

/* Submit Button */
.submit-section {
  margin-top: auto;
  padding-top: 30rpx;
}

.submit-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F65 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
}

.submit-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}
