.container {
  min-height: 100vh;
  background: #f4f8ff;
  padding: 24rpx;
  padding-bottom: 160rpx;
}
.status {
  margin-top: 120rpx;
  text-align: center;
  color: #64748b;
}
.card,
.panel {
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #d9e4fb;
  box-shadow: 0 6rpx 16rpx rgba(22, 82, 240, 0.08);
  padding: 20rpx;
  margin-bottom: 16rpx;
}
.head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.title {
  font-size: 34rpx;
  color: #0f172a;
  font-weight: 700;
}
.type,
.meta,
.line,
.bench {
  font-size: 24rpx;
  color: #64748b;
}
.score {
  margin-top: 10rpx;
  font-size: 50rpx;
  color: #0f172a;
  font-weight: 700;
}
.diff {
  color: #22c55e;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}
.tabs {
  display: flex;
  gap: 10rpx;
  margin-bottom: 16rpx;
}
.tab {
  flex: 1;
  text-align: center;
  border: 1rpx solid #d9e4fb;
  border-radius: 999rpx;
  padding: 12rpx 0;
  color: #64748b;
  font-size: 24rpx;
  background: #fff;
}
.tab.active {
  color: #1652f0;
  border-color: #1652f0;
  background: #eef4ff;
}
.row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
}
.player {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.name {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 600;
}
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 14rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
}
.btn-danger {
  background: #ef4444;
  color: #fff;
}
