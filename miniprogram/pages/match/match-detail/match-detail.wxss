/* pages/match/match-detail/match-detail.wxss */

.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f5f5 0%, #fff 100%);
}

/* 状态卡片 */
.status-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.match-type-tag {
  background: rgba(0, 143, 211, 0.1);
  color: var(--primary-color, #008FD3);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.match-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.match-status.scheduled {
  background: rgba(250, 140, 22, 0.1);
  color: #FA8C16;
}

.match-status.ongoing {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.match-status.finished {
  background: rgba(140, 140, 140, 0.1);
  color: #8C8C8C;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: currentColor;
}

.match-status.ongoing .status-dot {
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* 对阵信息 */
.versus-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.team-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
}

.team-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
  border: 4rpx solid #f0f0f0;
}

.team-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  text-align: center;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.team-label {
  font-size: 22rpx;
  color: #999;
}

.score-block {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-display {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.score-number {
  font-size: 64rpx;
  font-weight: bold;
  color: var(--primary-color, #008FD3);
}

.score-divider {
  font-size: 48rpx;
  color: #ccc;
}

.vs-display {
  padding: 20rpx;
}

.vs-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ccc;
}

/* 信息区域 */
.info-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.info-value.highlight {
  color: var(--primary-color, #008FD3);
  font-weight: 500;
  font-size: 32rpx;
}

/* 操作按钮 */
.action-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-btn .btn-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.action-btn text:last-child {
  font-size: 26rpx;
  color: #666;
}

.action-btn.danger text:last-child {
  color: #ff4d4f;
}

/* 快速操作 */
.debug-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.quick-actions {
  display: flex;
  gap: 20rpx;
}

.quick-btn {
  flex: 1;
  background: var(--primary-color, #008FD3);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 40rpx;
}

.score-input-group {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.score-input-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.team-label-input {
  font-size: 24rpx;
  color: #999;
}

.score-input {
  width: 120rpx;
  height: 100rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.score-colon {
  font-size: 48rpx;
  color: #ccc;
  align-self: center;
  margin-top: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: var(--primary-color, #008FD3);
  color: #fff;
}

/* 淡入动画 */
.fade-in {
  animation: fadeIn 300ms ease-out forwards;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 按钮交互 */
.btn-press {
  transition: all 100ms ease-out;
}

.btn-press:active {
  transform: scale(0.95);
  opacity: 0.8;
}
