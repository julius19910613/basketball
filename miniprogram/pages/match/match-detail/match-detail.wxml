<!--pages/match/match-detail/match-detail.wxml-->
<view class="container">
  <!-- 骨架屏 -->
  <skeleton 
    wx:if="{{loading}}"
    show-header="{{true}}"
    show-stats="{{true}}"
    show-list="{{false}}"
  ></skeleton>

  <!-- 真实内容 -->
  <view class="content {{loading ? '' : 'fade-in'}}" wx:if="{{!loading}}">
    <!-- 比赛状态卡片 -->
    <view class="status-card">
      <view class="match-type-tag">{{matchInfo.type === 'Friendly' ? '友谊赛' : '联赛'}}</view>
      <view class="match-status {{matchInfo.status}}">
        <text class="status-dot"></text>
        <text>{{statusText[matchInfo.status]}}</text>
      </view>
    </view>

    <!-- 对阵信息 -->
    <view class="versus-section">
      <view class="team-block">
        <image class="team-logo" src="{{matchInfo.homeTeam.logo || '/images/basketball-placeholder.svg'}}" mode="aspectFill"></image>
        <text class="team-name">{{matchInfo.homeTeam.name || '主队'}}</text>
        <text class="team-label">主队</text>
      </view>

      <view class="score-block">
        <view class="score-display" wx:if="{{matchInfo.status === 'finished'}}">
          <text class="score-number">{{matchInfo.homeScore || 0}}</text>
          <text class="score-divider">:</text>
          <text class="score-number">{{matchInfo.awayScore || 0}}</text>
        </view>
        <view class="vs-display" wx:else>
          <text class="vs-text">VS</text>
        </view>
      </view>

      <view class="team-block">
        <image class="team-logo" src="{{matchInfo.awayTeam.logo || '/images/basketball-placeholder.svg'}}" mode="aspectFill"></image>
        <text class="team-name">{{matchInfo.awayTeam.name || '待定'}}</text>
        <text class="team-label">客队</text>
      </view>
    </view>

    <!-- 比赛信息 -->
    <view class="info-section">
      <view class="section-title">比赛信息</view>
      
      <view class="info-item">
        <text class="info-icon">🕐</text>
        <view class="info-content">
          <text class="info-label">开始时间</text>
          <text class="info-value">{{formattedStartTime}}</text>
        </view>
      </view>

      <view class="info-item">
        <text class="info-icon">📍</text>
        <view class="info-content">
          <text class="info-label">比赛地点</text>
          <text class="info-value">{{matchInfo.location.name || '待定'}}</text>
        </view>
      </view>

      <view class="info-item" wx:if="{{matchInfo.status === 'finished'}}">
        <text class="info-icon">🏆</text>
        <view class="info-content">
          <text class="info-label">最终比分</text>
          <text class="info-value highlight">{{matchInfo.homeScore || 0}} : {{matchInfo.awayScore || 0}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section" wx:if="{{canEdit}}">
      <view class="action-btn btn-press" bindtap="editMatch" wx:if="{{matchInfo.status === 'scheduled'}}">
        <text class="btn-icon">✏️</text>
        <text>编辑比赛</text>
      </view>
      <view class="action-btn btn-press" bindtap="updateScore" wx:if="{{matchInfo.status === 'ongoing' || matchInfo.status === 'finished'}}">
        <text class="btn-icon">📊</text>
        <text>更新比分</text>
      </view>
      <view class="action-btn btn-press danger" bindtap="deleteMatch">
        <text class="btn-icon">🗑️</text>
        <text>删除比赛</text>
      </view>
    </view>

    <!-- 状态切换（测试用） -->
    <view class="debug-section" wx:if="{{canEdit && matchInfo.status !== 'finished'}}">
      <view class="section-title">快速操作</view>
      <view class="quick-actions">
        <view class="quick-btn btn-press" bindtap="startMatch" wx:if="{{matchInfo.status === 'scheduled'}}">
          <text>开始比赛</text>
        </view>
        <view class="quick-btn btn-press" bindtap="finishMatch" wx:if="{{matchInfo.status === 'ongoing'}}">
          <text>结束比赛</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 比分输入弹窗 -->
<view class="modal-mask" wx:if="{{showScoreModal}}" bindtap="hideScoreModal">
  <view class="modal-content" catchtap="preventClose">
    <view class="modal-title">更新比分</view>
    <view class="score-input-group">
      <view class="score-input-item">
        <text class="team-label-input">{{matchInfo.homeTeam.name || '主队'}}</text>
        <input class="score-input" type="number" value="{{tempHomeScore}}" bindinput="onHomeScoreInput" placeholder="0" />
      </view>
      <text class="score-colon">:</text>
      <view class="score-input-item">
        <text class="team-label-input">{{matchInfo.awayTeam.name || '客队'}}</text>
        <input class="score-input" type="number" value="{{tempAwayScore}}" bindinput="onAwayScoreInput" placeholder="0" />
      </view>
    </view>
    <view class="modal-actions">
      <view class="modal-btn cancel" bindtap="hideScoreModal">取消</view>
      <view class="modal-btn confirm" bindtap="confirmScore">确认</view>
    </view>
  </view>
</view>
