.container {
  min-height: 100vh;
  background: #f4f8ff;
  padding: 24rpx;
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.title {
  font-size: 40rpx;
  color: #0f172a;
  font-weight: 700;
}
.add-btn {
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  border: none;
  background: #1652f0;
  color: #fff;
  font-size: 26rpx;
  padding: 0 24rpx;
}
.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.tab {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #64748b;
  background: #fff;
  border: 1rpx solid #d9e4fb;
  border-radius: 999rpx;
  padding: 12rpx 0;
}
.tab-active {
  color: #1652f0;
  border-color: #1652f0;
  background: #eef4ff;
}
.status-text {
  text-align: center;
  color: #64748b;
  padding: 40rpx 0;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #d9e4fb;
  box-shadow: 0 6rpx 16rpx rgba(22, 82, 240, 0.08);
  margin-bottom: 16rpx;
  overflow: hidden;
}
.card-main {
  padding: 24rpx;
}
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.opponent {
  font-size: 30rpx;
  color: #0f172a;
  font-weight: 700;
}
.date,
.meta {
  font-size: 23rpx;
  color: #64748b;
}
.score {
  font-size: 36rpx;
  font-weight: 700;
}
.score-row {
  margin: 14rpx 0;
}
.score-win {
  color: #22c55e;
}
.score-loss {
  color: #ef4444;
}
.delete-btn {
  border: none;
  border-top: 1rpx solid #f1f5f9;
  border-radius: 0;
  color: #ef4444;
  background: #fff;
  font-size: 24rpx;
}
.type {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}
.tag-friendly {
  color: #1652f0;
  background: #eef4ff;
}
.tag-league {
  color: #f59e0b;
  background: #fffbeb;
}
.tag-cup {
  color: #8b5cf6;
  background: #f5f3ff;
}
.result-win {
  border-left: 6rpx solid #22c55e;
}
.result-loss {
  border-left: 6rpx solid #ef4444;
}
.result-draw {
  border-left: 6rpx solid #94a3b8;
}
