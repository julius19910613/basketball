<view class="container">
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:else>
    <view class="card">
      <view class="field multi-field">
        <text>比赛队伍 *</text>
        <view class="team-name-list">
          <view wx:for="{{form.teamNames}}" wx:key="index" class="team-name-row">
            <input value="{{item}}" data-index="{{index}}" bindinput="onTeamNameInput" placeholder="输入队伍名" />
            <button class="mini-remove" data-index="{{index}}" bindtap="onRemoveTeam">删除</button>
          </view>
          <button class="mini-add" bindtap="onAddTeam">新增队伍</button>
        </view>
      </view>
      <view class="field"><text>比赛日期 *</text><input value="{{form.matchDate}}" data-field="matchDate" bindinput="onInput" placeholder="YYYY-MM-DD" /></view>
      <view class="field"><text>开始时间</text><input value="{{form.startTime}}" data-field="startTime" bindinput="onInput" placeholder="如 19:00" /></view>
      <view class="field"><text>结束时间</text><input value="{{form.endTime}}" data-field="endTime" bindinput="onInput" placeholder="如 21:00" /></view>
      <view class="field"><text>比赛地点</text><input value="{{form.location}}" data-field="location" bindinput="onInput" placeholder="输入地点" /></view>
      <view class="field"><text>比赛类型</text><picker mode="selector" range="{{['友谊赛','联赛','杯赛','全场球赛 (FIBA)','全场球赛 (NCAA)']}}" bindchange="onTypeChange"><view>{{form.matchType === 'league' ? '联赛' : form.matchType === 'cup' ? '杯赛' : form.matchType === 'fiba' ? '全场球赛 (FIBA)' : form.matchType === 'ncaa' ? '全场球赛 (NCAA)' : '友谊赛'}}</view></picker></view>
      <view class="field" bindtap="onShowPlayerPicker">
        <text>参赛球员 *</text>
        <view class="picker-value">
          <text wx:if="{{selectedPlayerIds.length > 0}}" class="selected-count">已选 {{selectedPlayerIds.length}} 人（至少4人）</text>
          <text wx:else style="color: #64748b;">点击选择球员</text>
        </view>
      </view>
    </view>

    <view class="action-bar">
      <button class="btn btn-primary" loading="{{saving}}" disabled="{{saving}}" bindtap="onGoGrouping">下一步：进入分组</button>
    </view>
  </view>

  <van-popup
    show="{{ showPlayerPicker }}"
    position="bottom"
    round
    custom-style="height: 70%;"
    bind:close="onHidePlayerPicker"
  >
    <view class="popup-container">
      <view class="popup-header">
        <text class="popup-title">选择参赛球员</text>
        <van-button type="primary" size="small" round bind:click="onConfirmPlayers">确定</van-button>
      </view>
      <scroll-view scroll-y class="player-list-scroll">
        <van-cell-group border="{{ false }}">
          <van-cell
            title="{{ isAllPlayersSelected ? '取消全选' : '全选' }}"
            label="共 {{ players.length }} 人，已选 {{ tempSelectedPlayerIds.length }} 人"
            label-class="select-all-meta"
            clickable
            bind:click="onToggleSelectAllPlayers"
          >
            <view slot="right-icon" class="select-all-icon">
              <van-icon
                wx:if="{{ isAllPlayersSelected }}"
                name="checked"
                size="22px"
                color="#1652f0"
              />
              <van-icon
                wx:else
                name="circle"
                size="22px"
                color="#c8d2e1"
              />
            </view>
          </van-cell>
        </van-cell-group>
        <van-checkbox-group value="{{ tempSelectedPlayerIds }}" bind:change="onPlayerSelectionChange">
          <van-cell-group border="{{ false }}">
            <van-cell
              wx:for="{{ players }}"
              wx:key="playerId"
              title="{{ item.displayNickname }}"
              label="{{ item.displayPosition }}"
              clickable
              data-id="{{ item.playerId }}"
              bind:click="onTogglePlayerSelection"
            >
              <van-checkbox
                slot="right-icon"
                name="{{ item.playerId }}"
                catch:tap="noop"
                class="checkbox-{{ item.playerId }}"
              />
            </van-cell>
          </van-cell-group>
        </van-checkbox-group>
      </scroll-view>
    </view>
  </van-popup>
</view>
