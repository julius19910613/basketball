.container {
  min-height: 100vh;
  background: #f4f8ff;
  padding: 24rpx;
  padding-bottom: 160rpx;
}
.loading {
  text-align: center;
  color: #64748b;
  margin-top: 120rpx;
}
.tabs {
  display: flex;
  gap: 10rpx;
  margin-bottom: 18rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 999rpx;
  border: 1rpx solid #d9e4fb;
  background: #fff;
  color: #64748b;
  font-size: 24rpx;
}
.tab.active {
  color: #1652f0;
  border-color: #1652f0;
  background: #eef4ff;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #d9e4fb;
  box-shadow: 0 6rpx 16rpx rgba(22, 82, 240, 0.08);
  padding: 20rpx;
}
.field,
.score-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.field text,
.score-line text {
  color: #64748b;
  font-size: 24rpx;
}
.field input,
.score-line input {
  flex: 1;
  text-align: right;
  color: #0f172a;
  font-size: 26rpx;
}
.multi-field {
  align-items: flex-start;
}
.team-name-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.team-name-row {
  display: flex;
  gap: 10rpx;
  align-items: center;
}
.team-name-row input {
  flex: 1;
  text-align: left;
  background: #f8fbff;
  border: 1rpx solid #d9e4fb;
  border-radius: 10rpx;
  padding: 10rpx 12rpx;
  font-size: 24rpx;
}
.mini-add,
.mini-remove {
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 26rpx;
  border: none;
  font-size: 22rpx;
  padding: 0 16rpx;
}
.mini-add {
  background: #eef4ff;
  color: #1652f0;
}
.mini-remove {
  background: #fff1f2;
  color: #e11d48;
}
.summary {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #1652f0;
}
.picker-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #0f172a;
}
.selected-count {
  color: #1652f0;
  font-weight: 500;
}
.popup-container {
  display: flex;
  flex-direction: column;
  height: 100%;
}
.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f1f5f9;
}
.popup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #0f172a;
}
.player-list-scroll {
  flex: 1;
  overflow-y: auto;
}
.select-all-meta {
  color: #64748b;
  font-size: 22rpx;
}
.select-all-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 44rpx;
}
.action-bar {
...
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 14rpx;
}
