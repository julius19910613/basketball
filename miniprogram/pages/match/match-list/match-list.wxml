<!--pages/match/match-list/match-list.wxml-->
<view class="container">
  <!-- Tab 切换 -->
  <view class="tabs">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">即将开始</view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">已结束</view>
  </view>

  <!-- 比赛列表 -->
  <view class="match-list" wx:if="{{matchList.length > 0}}">
    <view class="match-card" wx:for="{{matchList}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}">
      <view class="match-header">
        <text class="match-type">{{item.type === 'Friendly' ? '友谊赛' : '联赛'}}</text>
        <text class="match-status {{item.status}}">{{statusText[item.status]}}</text>
      </view>
      <view class="match-teams">
        <view class="team-info">
          <image class="team-logo" src="{{item.homeTeam.logo || '/images/basketball-placeholder.svg'}}" mode="aspectFill"></image>
          <text class="team-name">{{item.homeTeam.name || '主队'}}</text>
        </view>
        <view class="vs-container">
          <text class="vs-text" wx:if="{{item.status === 'scheduled'}}">VS</text>
          <text class="match-score" wx:else>{{item.homeScore || 0}} : {{item.awayScore || 0}}</text>
        </view>
        <view class="team-info">
          <image class="team-logo" src="{{item.awayTeam.logo || '/images/basketball-placeholder.svg'}}" mode="aspectFill"></image>
          <text class="team-name">{{item.awayTeam.name || '客队'}}</text>
        </view>
      </view>
      <view class="match-footer">
        <text class="match-time">🕐 {{item.startTimeFormatted}}</text>
        <text class="match-location">📍 {{item.location.name || '待定'}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">🏀</text>
    <text class="empty-text">暂无{{currentTab === 0 ? '即将开始的' : '已结束的'}}比赛</text>
  </view>

  <!-- 创建比赛按钮 -->
  <view class="fab-button" bindtap="createMatch">
    <text class="fab-icon">+</text>
  </view>
</view>
