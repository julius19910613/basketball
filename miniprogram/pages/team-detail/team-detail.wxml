<!--pages/team-detail/team-detail.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 球队信息 -->
  <view class="team-info" wx:if="{{teamInfo && !loading}}">
    <!-- 队徽 -->
    <image 
      class="team-logo" 
      src="{{teamInfo.logo || '/images/logo.svg'}}" 
      mode="aspectFill"
    ></image>
    
    <!-- 基本信息 -->
    <view class="basic-info">
      <view class="team-name">{{teamInfo.name}}</view>
      <view class="team-meta">
        <text class="meta-item">
          <text class="icon">📍</text>
          {{teamInfo.region}}
        </text>
        <text class="meta-item">
          <text class="color-dot" style="background-color: {{teamInfo.color}};"></text>
          队服颜色
        </text>
      </view>
    </view>
  </view>

  <!-- 成员列表 -->
  <view class="members-section" wx:if="{{teamInfo && !loading}}">
    <view class="section-header">
      <text class="section-title">球队成员 ({{members.length}})</text>
      <view class="manage-btn" wx:if="{{isCaptain}}" bindtap="goToMemberManage">
        <text class="btn-text">管理</text>
        <text class="btn-icon">></text>
      </view>
    </view>

    <view class="members-list">
      <view class="member-item" wx:for="{{members}}" wx:key="_id">
        <!-- 头像 -->
        <image 
          class="avatar" 
          src="{{item.userInfo.avatarUrl || '/images/default_avatar.svg'}}" 
          mode="aspectFill"
        ></image>
        
        <!-- 信息 -->
        <view class="member-info">
          <view class="nickname">{{item.userInfo.nickName || '未命名'}}</view>
          <view class="role-tag captain" wx:if="{{item.role === 'captain'}}">队长</view>
          <view class="role-tag vice" wx:elif="{{item.role === 'vice-captain'}}">副队长</view>
          <view class="role-tag member" wx:else>队员</view>
        </view>

        <!-- 号码 -->
        <view class="number" wx:if="{{item.number}}">
          {{item.number}}号
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-members" wx:if="{{members.length === 0 && !loading}}">
    <text class="empty-text">暂无成员</text>
  </view>
</view>
