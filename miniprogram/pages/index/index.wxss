/* pages/index/index.wxss */
.container {
  padding: 30rpx;
  background-color: var(--background);
  min-height: 100vh;
}

/* Hero Section */
.hero-card {
  width: 100%;
  height: 320rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #fff;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(22, 82, 240, 0.2);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
}

.stat-label {
  font-size: 20rpx;
  opacity: 0.7;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

/* Section Title */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 24rpx;
  margin-top: 20rpx;
}

/* Grid Actions */
.action-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx !important;
  border-radius: 20rpx !important;
  background-color: #fff !important;
  border: 1rpx solid var(--card-border) !important;
  box-shadow: 0 6rpx 16rpx rgba(22, 82, 240, 0.05) !important;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.action-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 4rpx;
}

.action-desc {
  font-size: 20rpx;
  color: var(--light-text);
}

/* Secondary Actions */
.secondary-actions {
  background-color: #fff;
  border-radius: 20rpx;
  border: 1rpx solid var(--card-border);
  overflow: hidden;
  margin-bottom: 40rpx;
}

.action-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.action-item:last-child {
  border-bottom: none;
}

.action-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-wrapper.blue { background-color: #1652f0; }
.icon-wrapper.sky { background-color: #3b82f6; }

.action-info .name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
}

.action-info .desc {
  font-size: 22rpx;
  color: var(--light-text);
}

/* Footer Banner */
.footer-banner {
  width: 100%;
  height: 88rpx;
  background-color: #eef4ff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: var(--primary-color);
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 60rpx;
}
