/* pages/login/login.wxss */

.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  position: relative;
  overflow: hidden;
}

/* 装饰背景 */
.decorative-bg {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(255, 107, 53, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

.decorative-bg::after {
  content: '';
  position: absolute;
  bottom: -200rpx;
  left: -150rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(0, 255, 255, 0.2) 0%, transparent 70%);
  border-radius: 50%;
}

/* 主内容 */
.login-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx 60rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-container {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 30rpx;
  background: linear-gradient(135deg, #008FD3, #006B9F);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 60rpx rgba(255, 107, 53, 0.4);
}

.logo-text {
  font-size: 80rpx;
}

.logo {
  width: 100rpx;
  height: 100rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 2rpx;
}

/* 登录表单 */
.login-form {
  width: 100%;
  max-width: 600rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 50rpx;
}

.avatar-btn {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  overflow: visible;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  position: absolute;
  top: 0;
  left: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid #00FFFF;
  box-shadow: 0 0 40rpx rgba(0, 255, 255, 0.4);
}

.avatar-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  border: 4rpx dashed rgba(0, 255, 255, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.plus-icon {
  font-size: 60rpx;
  color: #00FFFF;
  line-height: 1;
}

.hint-text {
  font-size: 24rpx;
  color: rgba(0, 255, 255, 0.8);
  margin-top: 10rpx;
}

.avatar-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 200rpx;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 0 0 100rpx 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.change-text {
  font-size: 24rpx;
  color: #ffffff;
}

/* 昵称输入 */
.nickname-section {
  margin-bottom: 60rpx;
}

.nickname-input {
  width: 100%;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(0, 255, 255, 0.3);
  border-radius: 20rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
  font-size: 34rpx;
  color: #ffffff;
  text-align: center;
  transition: all 0.3s ease;
}

.nickname-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.nickname-input:focus {
  border-color: #00FFFF;
  background: rgba(0, 255, 255, 0.1);
  box-shadow: 0 0 30rpx rgba(0, 255, 255, 0.2);
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.1);
  border: none;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 4rpx;
  transition: all 0.3s ease;
}

.login-btn::after {
  border: none;
}

.login-btn.active {
  background: linear-gradient(135deg, #008FD3 0%, #006B9F 100%);
  color: #ffffff;
  box-shadow: 0 15rpx 40rpx rgba(255, 107, 53, 0.4);
}

.login-btn.active:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 53, 0.5);
}

.login-btn[disabled] {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.3);
}

/* 跳过登录 */
.skip-section {
  margin-top: 40rpx;
  text-align: center;
}

.skip-btn {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  text-decoration: underline;
}

/* 用户协议 */
.agreement {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.agreement-link {
  font-size: 24rpx;
  color: #00FFFF;
}
