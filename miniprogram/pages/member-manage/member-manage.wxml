<!--pages/member-manage/member-manage.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 球队信息 -->
  <view class="team-header" wx:if="{{teamInfo && !loading}}">
    <image 
      class="team-logo" 
      src="{{teamInfo.logo || '/images/default-logo.png'}}" 
      mode="aspectFill"
    ></image>
    <view class="team-name">{{teamInfo.name}}</view>
    <view class="member-count">共 {{members.length}} 名成员</view>
  </view>

  <!-- 邀请按钮 -->
  <view class="invite-section" wx:if="{{teamInfo && !loading}}">
    <button class="invite-btn" bindtap="showInvite">
      <text class="btn-icon">+</text>
      <text>邀请新成员</text>
    </button>
  </view>

  <!-- 成员列表 -->
  <view class="members-list" wx:if="{{teamInfo && !loading}}">
    <view class="member-item" wx:for="{{members}}" wx:key="_id" data-id="{{item._id}}" bindlongpress="showMemberMenu">
      <!-- 头像 -->
      <image 
        class="avatar" 
        src="{{item.userInfo.avatarUrl || '/images/default-avatar.png'}}" 
        mode="aspectFill"
      ></image>
      
      <!-- 信息 -->
      <view class="member-info">
        <view class="nickname">{{item.userInfo.nickName || '未命名'}}</view>
        <view class="role-row">
          <view class="role-tag captain" wx:if="{{item.role === 'captain'}}">队长</view>
          <view class="role-tag vice" wx:elif="{{item.role === 'vice-captain'}}">副队长</view>
          <view class="role-tag member" wx:else>队员</view>
        </view>
      </view>

      <!-- 号码 -->
      <view class="number" wx:if="{{item.number}}">
        {{item.number}}号
      </view>

      <!-- 更多图标（仅非队长显示） -->
      <view class="more-icon" wx:if="{{item.role !== 'captain'}}">···</view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{members.length === 0 && !loading}}">
    <text class="empty-text">暂无成员</text>
  </view>

  <!-- 邀请弹窗 -->
  <view class="modal-mask" wx:if="{{showInviteModal}}" bindtap="hideInviteModal">
    <view class="modal-content" catchtap="">
      <view class="modal-title">邀请新成员</view>
      <view class="modal-desc">分享小程序给好友，邀请他加入球队</view>
      <button class="share-btn" open-type="share">
        <text class="share-icon">📤</text>
        <text>分享给好友</text>
      </button>
      <button class="cancel-btn" bindtap="hideInviteModal">取消</button>
    </view>
  </view>
</view>
