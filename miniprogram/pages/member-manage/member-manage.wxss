/* pages/member-manage/member-manage.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999;
}

/* 球队头部 */
.team-header {
  background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.team-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-bottom: 20rpx;
  background-color: #fff;
}

.team-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.member-count {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 邀请区域 */
.invite-section {
  padding: 30rpx;
}

.invite-btn {
  width: 100%;
  height: 88rpx;
  background-color: #fff;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.invite-btn::after {
  border: none;
}

.btn-icon {
  font-size: 40rpx;
  line-height: 1;
}

/* 成员列表 */
.members-list {
  background-color: #fff;
  margin: 0 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  background-color: #fff;
}

.member-item:last-child {
  border-bottom: none;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background-color: #f0f0f0;
}

.member-info {
  flex: 1;
}

.nickname {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.role-row {
  display: flex;
  align-items: center;
}

.role-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.role-tag.captain {
  background-color: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
}

.role-tag.vice {
  background-color: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.role-tag.member {
  background-color: #E0E0E0;
  color: #999;
}

.number {
  padding: 8rpx 20rpx;
  background-color: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.more-icon {
  font-size: 40rpx;
  color: #ccc;
  padding: 10rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 邀请弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.share-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.share-btn::after {
  border: none;
}

.share-icon {
  font-size: 36rpx;
}

.cancel-btn {
  width: 100%;
  height: 88rpx;
  background-color: #fff;
  color: #999;
  border: 2rpx solid #eee;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.cancel-btn::after {
  border: none;
}
