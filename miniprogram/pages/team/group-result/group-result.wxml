<!--pages/team/group-result/group-result.wxml-->
<view class="container">
  <!-- 骨架屏 -->
  <skeleton 
    wx:if="{{!result}}"
    show-cards="{{true}}"
    card-count="{{3}}"
  ></skeleton>

  <!-- 无数据状态 -->
  <view class="empty-state fade-in" wx:if="{{!result && !loading}}">
    <text class="empty-icon">😕</text>
    <text class="empty-text">暂无分组数据</text>
    <view class="empty-btn btn-press" bindtap="goBack">返回重新分组</view>
  </view>

  <!-- 真实内容 -->
  <view class="content {{result ? 'fade-in' : ''}}" wx:if="{{result}}">
    <!-- 顶部统计 -->
    <view class="stats-header slide-in-up">
      <view class="stats-time">{{createTime}}</view>
      <view class="stats-summary">
        <text>{{stats.teamCount}}队</text>
        <text class="divider">·</text>
        <text>{{stats.totalPlayers}}人</text>
        <text class="divider">·</text>
        <text>平均档位差 {{stats.levelDifference}}</text>
      </view>
      <view class="balance-indicator {{stats.isBalanced ? 'balanced' : 'unbalanced'}}">
        <text>{{stats.isBalanced ? '✓ 平衡' : '⚠ 不够平衡'}}</text>
      </view>
    </view>

    <!-- 队伍卡片 -->
    <view class="teams-container">
      <view 
        class="team-card scale-in" 
        style="animation-delay: {{teamIndex * 100}}ms;"
        wx:for="{{teams}}" 
        wx:key="name"
        wx:for-index="teamIndex"
        wx:for-item="team"
      >
        <!-- 队伍头部 -->
        <view 
          class="team-header btn-press"
          data-index="{{teamIndex}}"
          bindtap="toggleTeamDetail"
        >
          <view class="team-name-area">
            <text class="team-name">{{team.name}}</text>
            <text class="team-avg">平均 {{team.avgLevel}} 档</text>
          </view>
          <view class="team-count">
            <text>{{team.players.length}}人</text>
            <text class="expand-icon">{{showTeamDetail === teamIndex ? '▼' : '▶'}}</text>
          </view>
        </view>

        <!-- 队伍成员列表 -->
        <view class="team-players {{showTeamDetail === teamIndex ? 'expanded' : ''}}">
          <view 
            class="player-row list-item-enter delay-{{playerIndex * 50}}" 
            wx:for="{{team.players}}" 
            wx:for-item="player"
            wx:for-index="playerIndex"
            wx:key="_id"
          >
            <image class="player-avatar avatar-pop" src="{{player.avatar}}" mode="aspectFill"></image>
            <view class="player-info">
              <text class="player-name">{{player.name}}</text>
              <text class="player-meta">{{player.number}}号 · {{player.position}}</text>
            </view>
            <view class="player-level" style="background-color: {{player.levelColor}};">
              <text>{{player.skillLevel}}档</text>
            </view>
          </view>
        </view>

        <!-- 队伍成员概览（折叠状态） -->
        <view class="team-preview" wx:if="{{showTeamDetail !== teamIndex}}">
          <view class="preview-avatars">
            <image 
              class="preview-avatar avatar-pop" 
              wx:for="{{team.players}}" 
              wx:if="{{index < 5}}"
              wx:key="_id"
              src="{{item.avatar}}"
              mode="aspectFill"
            ></image>
            <view class="preview-more" wx:if="{{team.players.length > 5}}">
              <text>+{{team.players.length - 5}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 档位分布对比 -->
    <view class="level-comparison fade-in" style="animation-delay: 300ms;">
      <view class="section-title">档位分布对比</view>
      <view class="comparison-chart">
        <view class="chart-row" wx:for="{{levelComparisonData}}" wx:key="level">
          <view class="chart-label">{{item.level}}档</view>
          <view class="chart-bars">
            <view 
              class="chart-bar" 
              wx:for="{{item.teams}}" 
              wx:key="name"
              wx:for-item="team"
              wx:for-index="teamIdx"
            >
              <view 
                class="bar-fill" 
                style="width: {{team.count * 20}}%;"
              ></view>
              <text class="bar-count">{{team.count}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="chart-legend">
        <text wx:for="{{teams}}" wx:key="name" class="legend-item">{{item.name}}</text>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar bottom-bar-enter">
      <view class="action-btn btn-press" bindtap="regroup">
        <text class="btn-icon">🔄</text>
        <text class="btn-text">重新分组</text>
      </view>
      <view class="action-btn btn-press" bindtap="copyResult">
        <text class="btn-icon">📋</text>
        <text class="btn-text">复制结果</text>
      </view>
      <view class="action-btn primary btn-press {{saved ? 'disabled' : ''}}" bindtap="saveGroup">
        <text class="btn-icon">{{saved ? '✓' : '💾'}}</text>
        <text class="btn-text">{{saved ? '已保存' : '保存'}}</text>
      </view>
      <button class="action-btn share btn-press" open-type="share">
        <text class="btn-icon">📤</text>
        <text class="btn-text">分享</text>
      </button>
    </view>
  </view>
</view>
