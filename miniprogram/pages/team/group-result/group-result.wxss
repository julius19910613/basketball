/* pages/team/group-result/group-result.wxss */

/* 引入动画库 */
@import '/styles/animations.wxss';

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 内容淡入动画 */
.content {
  opacity: 0;
  transition: opacity 300ms ease-out;
}

.content.fade-in {
  opacity: 1;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 20rpx 48rpx;
  background-color: #008FD3;
  border-radius: 40rpx;
}

.empty-btn text {
  font-size: 28rpx;
  color: #fff;
}

/* 顶部统计 */
.stats-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
  background: linear-gradient(135deg, #008FD3 0%, #33A8E0 100%);
  color: #fff;
}

.stats-time {
  font-size: 24rpx;
  opacity: 0.8;
  margin-bottom: 12rpx;
}

.stats-summary {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  margin-bottom: 12rpx;
}

.divider {
  margin: 0 12rpx;
  opacity: 0.6;
}

.balance-indicator {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.balance-indicator.balanced {
  background-color: rgba(255, 255, 255, 0.2);
}

.balance-indicator.unbalanced {
  background-color: rgba(255, 200, 0, 0.3);
}

/* 队伍容器 */
.teams-container {
  padding: 20rpx;
}

.team-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 队伍头部 */
.team-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #fafafa;
}

.team-name-area {
  display: flex;
  flex-direction: column;
}

.team-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.team-avg {
  font-size: 24rpx;
  color: #999;
}

.team-count {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.expand-icon {
  font-size: 20rpx;
  color: #999;
}

/* 队伍成员列表 */
.team-players {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.team-players.expanded {
  max-height: 2000rpx;
}

.player-row {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.player-row:last-child {
  border-bottom: none;
}

.player-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background-color: #f0f0f0;
}

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.player-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.player-meta {
  font-size: 22rpx;
  color: #999;
}

.player-level {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.player-level text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

/* 队伍成员概览 */
.team-preview {
  padding: 16rpx 24rpx;
}

.preview-avatars {
  display: flex;
  align-items: center;
}

.preview-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: -12rpx;
  border: 2rpx solid #fff;
  background-color: #f0f0f0;
}

.preview-more {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -12rpx;
  border: 2rpx solid #fff;
}

.preview-more text {
  font-size: 20rpx;
  color: #666;
}

/* 档位分布对比 */
.level-comparison {
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.comparison-chart {
  
}

.chart-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.chart-row:last-child {
  margin-bottom: 0;
}

.chart-label {
  width: 80rpx;
  font-size: 24rpx;
  color: #666;
}

.chart-bars {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.chart-bar {
  display: flex;
  align-items: center;
  height: 28rpx;
  background-color: #f5f5f5;
  border-radius: 4rpx;
  overflow: hidden;
  position: relative;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #008FD3, #33A8E0);
  border-radius: 4rpx;
}

.bar-count {
  position: absolute;
  right: 8rpx;
  font-size: 20rpx;
  color: #666;
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.legend-item {
  font-size: 22rpx;
  color: #999;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 16rpx 20rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  background-color: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.action-btn.primary {
  background-color: #008FD3;
}

.action-btn.primary .btn-text {
  color: #fff;
}

.action-btn.disabled {
  opacity: 0.6;
}

.action-btn.share {
  padding: 16rpx 8rpx;
  margin: 0;
  line-height: normal;
}

.action-btn.share::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.btn-text {
  font-size: 22rpx;
  color: #666;
}
