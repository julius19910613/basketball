/* pages/team/random-group/random-group.wxss */

/* 引入动画库 */
@import '/styles/animations.wxss';

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 内容淡入动画 */
.content {
  opacity: 0;
  transition: opacity 300ms ease-out;
}

.content.fade-in {
  opacity: 1;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  color: #999;
  font-size: 28rpx;
}

/* 已选统计 */
.selected-summary {
  margin: 20rpx;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.summary-count {
  font-size: 32rpx;
  font-weight: 600;
  color: #008FD3;
}

.summary-levels {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.level-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.level-badge text {
  font-size: 22rpx;
  color: #fff;
}

/* 队伍数量选择 */
.team-count-section {
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.picker-display text:first-child {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 预设方案 */
.presets-section {
  margin: 0 20rpx 20rpx;
}

.presets-scroll {
  white-space: nowrap;
}

.preset-list {
  display: inline-flex;
  gap: 16rpx;
}

.preset-card {
  display: inline-block;
  padding: 20rpx 32rpx;
  background-color: #fff;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.preset-card.active {
  border-color: #008FD3;
  background-color: #FFF8F5;
}

.preset-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.preset-card.active .preset-label {
  color: #008FD3;
}

.preset-desc {
  font-size: 24rpx;
  color: #999;
}

/* 验证提示 */
.validation-section {
  margin: 0 20rpx 20rpx;
}

.validation-errors,
.validation-warnings {
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.validation-errors {
  background-color: #FFF2F0;
}

.validation-warnings {
  background-color: #FFFBE6;
}

.error-item,
.warning-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.error-item:last-child,
.warning-item:last-child {
  margin-bottom: 0;
}

.error-icon,
.warning-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.error-text {
  font-size: 26rpx;
  color: #CF1322;
}

.warning-text {
  font-size: 26rpx;
  color: #D48806;
}

/* 球员选择区域 */
.players-section {
  margin: 0 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-actions {
  display: flex;
  align-items: center;
}

.action-link {
  font-size: 26rpx;
  color: #008FD3;
}

.action-divider {
  margin: 0 16rpx;
  color: #ddd;
}

/* 按档位分组 */
.players-by-level {
  
}

.level-group {
  margin-bottom: 24rpx;
}

.level-group:last-child {
  margin-bottom: 0;
}

.level-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.level-indicator {
  width: 8rpx;
  height: 24rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.level-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
}

.level-count {
  margin-left: auto;
  font-size: 24rpx;
  color: #999;
}

.level-players {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.player-chip {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.player-chip.selected {
  background-color: #FFEDE5;
  border-color: #008FD3;
}

.player-chip text:first-child {
  font-size: 26rpx;
  color: #333;
}

.player-chip.selected text:first-child {
  color: #008FD3;
  font-weight: 500;
}

.chip-check {
  margin-left: 8rpx;
  font-size: 22rpx;
  color: #008FD3;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  background-color: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  gap: 20rpx;
}

.quick-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  background-color: #f5f5f5;
  border-radius: 40rpx;
}

.quick-btn text {
  font-size: 30rpx;
  color: #666;
}

.start-btn {
  flex: 2;
  padding: 24rpx;
  text-align: center;
  background-color: #008FD3;
  border-radius: 40rpx;
}

.start-btn.disabled {
  background-color: #ccc;
}

.start-btn text {
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
}
