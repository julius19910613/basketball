<!--pages/team/random-group/random-group.wxml-->
<view class="container">
  <!-- 骨架屏 -->
  <skeleton 
    wx:if="{{loading}}"
    show-selector="{{true}}"
  ></skeleton>

  <!-- 真实内容 -->
  <view class="content {{loading ? '' : 'fade-in'}}" wx:if="{{!loading}}">
    <!-- 已选统计 -->
    <view class="selected-summary">
      <view class="summary-header">
        <text class="summary-title">已选球员</text>
        <text class="summary-count">{{selectedStats.total}} 人</text>
      </view>
      <view class="summary-levels">
        <view class="level-badge" style="background-color: #FF4D4F;">
          <text>5档: {{selectedStats.level5}}</text>
        </view>
        <view class="level-badge" style="background-color: #FA8C16;">
          <text>4档: {{selectedStats.level4}}</text>
        </view>
        <view class="level-badge" style="background-color: #52C41A;">
          <text>3档: {{selectedStats.level3}}</text>
        </view>
        <view class="level-badge" style="background-color: #1890FF;">
          <text>2档: {{selectedStats.level2}}</text>
        </view>
      </view>
    </view>

    <!-- 队伍数量选择 -->
    <view class="team-count-section">
      <view class="section-title">分成几队？</view>
      <picker mode="selector" range="{{['2队', '3队', '4队']}}" value="{{teamCount - 2}}" bindchange="onTeamCountChange">
        <view class="picker-display btn-press">
          <text>{{teamCount}} 队</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 预设方案 -->
    <view class="presets-section" wx:if="{{presets.length > 0}}">
      <view class="section-title">推荐方案</view>
      <scroll-view class="presets-scroll" scroll-x>
        <view class="preset-list">
          <view 
            class="preset-card btn-press {{teamCount === item.teams ? 'active' : ''}}" 
            wx:for="{{presets}}" 
            wx:key="teams"
            data-teams="{{item.teams}}"
            bindtap="selectPreset"
          >
            <view class="preset-label">{{item.label}}</view>
            <view class="preset-desc">{{item.desc}}</view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 验证提示 -->
    <view class="validation-section" wx:if="{{validationResult}}">
      <!-- 错误提示 -->
      <view class="validation-errors shake" wx:if="{{validationResult.errors.length > 0}}">
        <view class="error-item" wx:for="{{validationResult.errors}}" wx:key="index">
          <text class="error-icon">⚠️</text>
          <text class="error-text">{{item}}</text>
        </view>
      </view>
      <!-- 警告提示 -->
      <view class="validation-warnings" wx:if="{{validationResult.warnings.length > 0}}">
        <view class="warning-item" wx:for="{{validationResult.warnings}}" wx:key="index">
          <text class="warning-icon">💡</text>
          <text class="warning-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 球员选择 -->
    <view class="players-section">
      <view class="section-header">
        <text class="section-title">选择球员</text>
        <view class="header-actions">
          <text class="action-link btn-press" bindtap="selectAll">全选</text>
          <text class="action-divider">|</text>
          <text class="action-link btn-press" bindtap="deselectAll">取消</text>
        </view>
      </view>

      <!-- 按档位分组显示 -->
      <view class="players-by-level">
        <!-- 5档 -->
        <view class="level-group" wx:if="{{levelStats.level5 > 0}}">
          <view class="level-header">
            <view class="level-indicator" style="background-color: #FF4D4F;"></view>
            <text class="level-text">5档 - 顶级球员</text>
            <text class="level-count">{{selectedStats.level5}}/{{levelStats.level5}}</text>
          </view>
          <view class="level-players">
            <view 
              class="player-chip player-chip-animated {{item.selected ? 'selected' : ''}}" 
              wx:for="{{allPlayers}}" 
              wx:if="{{item.skillLevel === 5}}"
              wx:key="_id"
              data-id="{{item._id}}"
              bindtap="togglePlayer"
            >
              <text>{{item.name}}</text>
              <text class="chip-check success-check" wx:if="{{item.selected}}">✓</text>
            </view>
          </view>
        </view>

        <!-- 4档 -->
        <view class="level-group" wx:if="{{levelStats.level4 > 0}}">
          <view class="level-header">
            <view class="level-indicator" style="background-color: #FA8C16;"></view>
            <text class="level-text">4档 - 优秀球员</text>
          </view>
          <view class="level-players">
            <view 
              class="player-chip player-chip-animated {{item.selected ? 'selected' : ''}}" 
              wx:for="{{allPlayers}}" 
              wx:if="{{item.skillLevel === 4}}"
              wx:key="_id"
              data-id="{{item._id}}"
              bindtap="togglePlayer"
            >
              <text>{{item.name}}</text>
              <text class="chip-check success-check" wx:if="{{item.selected}}">✓</text>
            </view>
          </view>
        </view>

        <!-- 3档 -->
        <view class="level-group" wx:if="{{levelStats.level3 > 0}}">
          <view class="level-header">
            <view class="level-indicator" style="background-color: #52C41A;"></view>
            <text class="level-text">3档 - 普通球员</text>
          </view>
          <view class="level-players">
            <view 
              class="player-chip player-chip-animated {{item.selected ? 'selected' : ''}}" 
              wx:for="{{allPlayers}}" 
              wx:if="{{item.skillLevel === 3}}"
              wx:key="_id"
              data-id="{{item._id}}"
              bindtap="togglePlayer"
            >
              <text>{{item.name}}</text>
              <text class="chip-check success-check" wx:if="{{item.selected}}">✓</text>
            </view>
          </view>
        </view>

        <!-- 2档 -->
        <view class="level-group" wx:if="{{levelStats.level2 > 0}}">
          <view class="level-header">
            <view class="level-indicator" style="background-color: #1890FF;"></view>
            <text class="level-text">2档 - 新手球员</text>
          </view>
          <view class="level-players">
            <view 
              class="player-chip player-chip-animated {{item.selected ? 'selected' : ''}}" 
              wx:for="{{allPlayers}}" 
              wx:if="{{item.skillLevel === 2}}"
              wx:key="_id"
              data-id="{{item._id}}"
              bindtap="togglePlayer"
            >
              <text>{{item.name}}</text>
              <text class="chip-check success-check" wx:if="{{item.selected}}">✓</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar bottom-bar-enter">
      <view class="quick-btn btn-press" bindtap="quickGroup">
        <text>快速分组</text>
      </view>
      <view class="start-btn btn-press {{validationResult.valid ? '' : 'disabled'}}" bindtap="startGrouping">
        <text>开始分组</text>
      </view>
    </view>
  </view>
  
  <!-- 分组动画组件 -->
  <group-animation 
    visible="{{showGroupAnimation}}"
    players="{{animationPlayers}}"
    teams="{{animationTeams}}"
    bind:complete="onAnimationComplete"
  ></group-animation>
</view>
