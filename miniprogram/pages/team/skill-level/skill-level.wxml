<!--pages/team/skill-level/skill-level.wxml-->
<view class="container">
  <!-- 骨架屏 -->
  <skeleton 
    wx:if="{{loading}}"
    show-stats="{{true}}"
    show-list="{{true}}"
    list-count="{{8}}"
    list-title="{{true}}"
    show-arrows="{{true}}"
  ></skeleton>

  <!-- 真实内容 -->
  <view class="content {{loading ? '' : 'fade-in'}}" wx:if="{{!loading}}">
    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stats-header">
        <text class="stats-title">档位分布</text>
        <text class="stats-total">共 {{stats.total}} 人</text>
      </view>
      <view class="stats-levels">
        <view class="level-stat">
          <view class="level-dot" style="background-color: #FF4D4F;"></view>
          <text class="level-label">5档</text>
          <text class="level-count">{{stats.level5}}人</text>
        </view>
        <view class="level-stat">
          <view class="level-dot" style="background-color: #FA8C16;"></view>
          <text class="level-label">4档</text>
          <text class="level-count">{{stats.level4}}人</text>
        </view>
        <view class="level-stat">
          <view class="level-dot" style="background-color: #52C41A;"></view>
          <text class="level-label">3档</text>
          <text class="level-count">{{stats.level3}}人</text>
        </view>
        <view class="level-stat">
          <view class="level-dot" style="background-color: #1890FF;"></view>
          <text class="level-label">2档</text>
          <text class="level-count">{{stats.level2}}人</text>
        </view>
      </view>
      <view class="stats-avg">
        <text>平均档位：{{stats.avgLevel}}</text>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="quick-actions">
      <view class="action-btn btn-press" bindtap="autoBalance">
        <text class="action-icon">⚡</text>
        <text class="action-text">自动平衡</text>
      </view>
      <view class="action-btn btn-press" bindtap="resetAll">
        <text class="action-icon">🔄</text>
        <text class="action-text">重置档位</text>
      </view>
    </view>

    <!-- 球员列表 -->
    <view class="players-section">
      <view class="section-header">
        <text class="section-title">球员列表</text>
        <text class="section-tip">点击球员修改档位</text>
      </view>

      <view class="players-list">
        <view 
          class="player-item list-item-enter delay-{{index * 50 > 500 ? 500 : index * 50}}" 
          wx:for="{{players}}" 
          wx:key="_id"
          data-id="{{item._id}}"
          bindtap="onPlayerTap"
        >
          <!-- 头像 -->
          <image class="avatar avatar-pop" src="{{item.avatar}}" mode="aspectFill"></image>
          
          <!-- 信息 -->
          <view class="player-info">
            <view class="player-name">{{item.name}}</view>
            <view class="player-meta">
              <text class="player-number">{{item.number}}号</text>
              <text class="player-position">{{item.position}}</text>
            </view>
          </view>
          
          <!-- 档位标签 -->
          <view class="level-tag" style="background-color: {{item.levelColor}};">
            <text>{{item.skillLevel}}档</text>
          </view>
          
          <!-- 箭头 -->
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && players.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无球员数据</text>
    </view>
  </view>

  <!-- 档位选择器弹窗 -->
  <view class="picker-mask mask-enter {{showLevelPicker ? '' : 'mask-leave'}}" wx:if="{{showLevelPicker}}" bindtap="closeLevelPicker">
    <view class="picker-container popup-enter" catchtap="preventBubble">
      <view class="picker-header">
        <text class="picker-title">选择档位</text>
        <text class="picker-close btn-press" bindtap="closeLevelPicker">✕</text>
      </view>
      
      <view class="picker-player">
        <text>正在设置：{{editingPlayer.name}}</text>
      </view>
      
      <view class="picker-options">
        <view 
          class="picker-option btn-press" 
          wx:for="{{levelOptions}}" 
          wx:key="value"
          data-level="{{item.value}}"
          bindtap="onLevelSelect"
        >
          <view class="option-dot" style="background-color: {{item.color}};"></view>
          <text class="option-label">{{item.label}}</text>
          <view class="option-check success-check" wx:if="{{editingPlayer.skillLevel === item.value}}">✓</view>
        </view>
      </view>
    </view>
  </view>
</view>
