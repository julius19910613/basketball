/* pages/team/skill-level/skill-level.wxss */

/* 引入动画库 */
@import '/styles/animations.wxss';

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 内容淡入动画 */
.content {
  opacity: 0;
  transition: opacity 300ms ease-out;
}

.content.fade-in {
  opacity: 1;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  color: #999;
  font-size: 28rpx;
}

/* 统计卡片 */
.stats-card {
  margin: 20rpx;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.stats-total {
  font-size: 26rpx;
  color: #999;
}

.stats-levels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.level-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.level-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
}

.level-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.level-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.stats-avg {
  text-align: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  color: #666;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  margin: 0 20rpx 20rpx;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.action-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.action-text {
  font-size: 28rpx;
  color: #333;
}

/* 球员列表区域 */
.players-section {
  margin: 0 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-tip {
  font-size: 24rpx;
  color: #999;
}

/* 球员列表 */
.players-list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.player-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.player-item:last-child {
  border-bottom: none;
}

.player-item:active {
  background-color: #f9f9f9;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.player-info {
  flex: 1;
}

.player-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.player-meta {
  display: flex;
  gap: 16rpx;
}

.player-number,
.player-position {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 12rpx;
  background-color: #f5f5f5;
  border-radius: 6rpx;
}

.level-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.level-tag text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 档位选择器弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-container {
  width: 100%;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

.picker-player {
  padding: 24rpx 32rpx;
  background-color: #f9f9f9;
  font-size: 28rpx;
  color: #666;
}

.picker-options {
  padding: 16rpx 0;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
}

.picker-option:active {
  background-color: #f9f9f9;
}

.option-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.option-label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.option-check {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #52C41A;
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
}
