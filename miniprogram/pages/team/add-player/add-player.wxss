.container {
  padding-bottom: 120rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

/* Overall 卡片 */
.overall-card {
  margin: 30rpx;
  padding: 40rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.overall-header {
  display: flex;
  flex-direction: column;
}

.overall-num {
  font-size: 120rpx;
  font-weight: 900;
  line-height: 1;
}

.overall-label {
  font-size: 24rpx;
  color: #666;
  letter-spacing: 4rpx;
  margin-top: 10rpx;
}

.position-badge {
  padding: 15rpx 30rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.position-icon {
  font-size: 32rpx;
}

.position-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

/* 表单区域 */
.form-section {
  background: #fff;
  margin: 0 30rpx 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  padding: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.item-input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 25rpx;
  font-size: 30rpx;
}

.item-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 25rpx;
  font-size: 30rpx;
}

.picker-arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 底部按钮 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.submit-btn[disabled] {
  background: #ccc;
}
